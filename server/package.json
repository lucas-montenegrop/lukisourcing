{
  "name": "lukisourcing-server",
  "type": "module",
  "imports": {
    "#*": "./*.js"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:schema": "psql \"$DATABASE_URL\" -f db/schema.sql",
    "db:seed": "node db/seed.js",
    "db:reset": "npm run db:schema && npm run db:seed"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "nodemon": "^3.1.14",
    "pg": "^8.14.1"
  }
}
